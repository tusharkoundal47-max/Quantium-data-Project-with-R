## Step 3: Data cleaning
Date data format from excel file needs to be converted in correct format, since excel counts dates as days elipsed since 1900

```{r}
library(lubridate)

cleaned_data <- combined_data %>% mutate(DATE = as.Date(DATE, origin = "1899-12-30"))

head(cleaned_data$DATE)

```

Segregating data into 3 age groups & merging individual brands

```{r}
cleaned_data <- combined_data %>% mutate(AGE_GROUP = case_when(
str_detect(LIFESTAGE, "(?i)Young|NEW") ~ "YOUNGSTERS",
str_detect(LIFESTAGE, "(?i)MIDAGE") ~ "MIDAGED People",
str_detect(LIFESTAGE, "(?i)OLDER|RETIREES") ~ "OLDER People",
TRUE ~ "Other"
)) %>%

mutate(BRAND = str_to_upper(word(PROD_NAME, 1))) %>% 
mutate(BRAND = case_when(
BRAND == "RRD" ~ "Red Rock Deli",
BRAND == "SMITH" ~ "SMITH",
BRAND == "DORITO" ~ "DORITOS",
BRAND == "WW" ~ "WOOLWORTHS",
BRAND == "Snbts" ~ "Sunbites",
BRAND == "GrnWves" ~ "Grain Waves",
TRUE ~ BRAND
))
```
