##### Running R analysis and removing salsa products

```{r}
combined_data <- cleaned_data %>% mutate(DATE = as.Date(DATE, origin = "1899-12-30")) %>% mutate(AGE_GROUP = case_when( str_detect(LIFESTAGE, "(?i)Young|NEW") ~ "YOUNGSTERS", str_detect(LIFESTAGE, "(?i)MIDAGE") ~ "MIDAGED People", str_detect(LIFESTAGE, "(?i)OLDER|RETIREES") ~ "OLDER People", TRUE ~ "Other")) %>% mutate(BRAND = str_to_upper(word(PROD_NAME, 1))) %>% mutate(BRAND = case_when(
    BRAND == "RRD" ~ "Red Rock Deli",
    BRAND == "SMITH" ~ "SMITH",
    BRAND == "DORITO" ~ "DORITOS",
    BRAND == "WW" ~ "WOOLWORTHS",
    BRAND == "SNBTS" ~ "Sunbites", # Ensure this matches the str_to_upper conversion
    BRAND == "GRNWVES" ~ "Grain Waves", TRUE ~ BRAND))
  
```


```{r}
unsalsa_data <- combined_data %>% filter(!str_detect(str_to_lower(PROD_NAME), "salsa"))
```


## Step 5: Further Analysis for Strategic Recommendations

To answer Julia's question about customer segments, we need to look at the key metrics grouped by LIFESTAGE and PREMIUM_CUSTOMER:

Total Sales: Which segment brings in the most revenue?

Buying Frequency/Quantity: Are they buying more bags of chips, or are there just more customers in that segment?

Average Price: Which segment buys the premium/expensive chips?

##### Summary table of your customer segments

```{r}
sales_summary <- unsalsa_data %>%
  group_by(LIFESTAGE, PREMIUM_CUSTOMER) %>%
  summarise(
    Total_Sales = sum(TOT_SALES, na.rm = TRUE),
    Total_Quantity = sum(PROD_QTY, na.rm = TRUE),
    Unique_Customers = n_distinct(LYLTY_CARD_NBR),
    .groups = 'drop'
  ) %>%
  mutate(Avg_Units_Per_Customer = Total_Quantity / Unique_Customers, Avg_Price_Per_Unit = Total_Sales / Total_Quantity
  ) %>%
  arrange(desc(Total_Sales))


head(sales_summary)
```

## Step 6: Generating visualisations in R and then in Tableau

#### Total Sales by segment

```{r}
ggplot(sales_summary, aes(x = Total_Sales, y = reorder(LIFESTAGE, Total_Sales), fill = PREMIUM_CUSTOMER)) +
  geom_col(position = "dodge") +
  labs(
    title = "Total Chip Sales by Customer Segment",
    x = "Total Sales ($)",
    y = "Customer Lifestage",
    fill = "Customer Type"
  ) +
  theme_minimal()
```


#### Average price per unit

```{r}
ggplot(sales_summary, aes(x = Avg_Price_Per_Unit, y = reorder(LIFESTAGE, Avg_Price_Per_Unit), fill = PREMIUM_CUSTOMER)) +
  geom_col(position = "dodge") +
  labs(
    title = "Average Price Paid Per Unit of Chips",
    x = "Average Price ($)",
    y = "Customer Lifestage",
    fill = "Customer Type"
  ) +
  theme_minimal()
```

